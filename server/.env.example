PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/filingbuddy
# Optional Railway-style fallback if your platform injects MONGO_URL instead.
MONGO_URL=
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=filing-buddy-task-portal
AWS_S3_UPLOAD_PREFIX=filing-buddy
# Optional. Use when serving S3 through CloudFront or a custom public bucket URL.
AWS_S3_PUBLIC_URL=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
CLIENT_URL=http://localhost:5173
